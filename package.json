{
  "name": "@cwap/evm",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:c1": "hardhat test __tests__/C1_EVM.ts __tests__/C1_ERC20_BEP20.ts",
    "test:c1:fees": "hardhat test __tests__/C1_EVM.fees.spec.ts __tests__/C1_ERC20_BEP20.fees.spec.ts",
    "test:c1:reentrancy": "hardhat test __tests__/C1_EVM.reentrancy.spec.ts",
    "test:c1:stress": "hardhat test __tests__/C1_EVM.stress.ts __tests__/C1_ERC20_BEP20.stress.ts",
    "test:c1:all": "hardhat test __tests__/C1_EVM.ts __tests__/C1_ERC20_BEP20.ts __tests__/C1_EVM.fees.spec.ts __tests__/C1_ERC20_BEP20.fees.spec.ts __tests__/C1_EVM.reentrancy.spec.ts",
    "test:gas": "hardhat test __tests__/C1_EVM.ts __tests__/C2_EVM.ts __tests__/C1_ERC20_BEP20.ts __tests__/C2_ERC20_BEP20.ts --grep Gas",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:holesky": "hardhat run scripts/deploy.ts --network holesky",
    "deploy:l1a": "hardhat run scripts/deploy.ts --network l1a",
    "deploy:l1b": "hardhat run scripts/deploy.ts --network l1b",
    "deploy:bsc": "hardhat run scripts/deploy.ts --network bsc",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network mainnet",
    "deploy:polygon": "hardhat run scripts/deploy.ts --network polygon",
    "deploy:tron": "npx tsx scripts/deploy-tron.ts",
    "deploy:bscTest:token": "hardhat run scripts/deploy-token.ts --network bscTest",
    "deploy:l1a:token": "hardhat run scripts/deploy-token.ts --network l1a",
    "node": "hardhat node",
    "clean": "hardhat clean"
  },
  "packageManager": "yarn@4.13.0",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.1",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^3.0.3",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.0.3",
    "@nomicfoundation/hardhat-keystore": "^3.0.1",
    "@nomicfoundation/hardhat-mocha": "^3.0.2",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-typechain": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^3.0.2",
    "@nomicfoundation/ignition-core": "^3.0.3",
    "@openzeppelin/contracts": "^5.1.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^5.2.2",
    "@types/cli-progress": "^3.11.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.6.1",
    "ansi-colors": "^4.1.3",
    "chai": "4.3.7",
    "cli-progress": "^3.12.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.15.0",
    "hardhat": "^3.0.6",
    "hardhat-gas-reporter": "^2.3.0",
    "hardhat-ignition": "^0.0.1",
    "solidity-coverage": "^0.8.16",
    "tronweb": "^6.2.0",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2"
  }
